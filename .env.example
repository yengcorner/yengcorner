// Đoạn này gửi trực tiếp, không qua backend nên không bao giờ bị lỗi 404
const sendEmail = async (emailData) => {
  try {
    const response = await fetch('https://gmail.googleapis.com/gmail/v1/users/me/messages/send', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${YOUR_ACCESS_TOKEN}`, // Cái này bồ lấy từ phần bồ đã cấu hình Gmail
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ raw: btoa(emailData) })
    });
    
    if (response.ok) {
      showToast("✅ Gửi email thành công!", "success");
    }
  } catch (error) {
    showToast("❌ Lỗi gửi email: " + error.message, "error");
  }
};
