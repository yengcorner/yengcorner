{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/unsubscribe",
      "destination": "/api/index"
    },
    {
      "source": "/assets/:path*",
      "destination": "/dist/assets/:path*"
    },
    {
      "source": "/((?!api|unsubscribe|assets).*)",
      "destination": "/dist/index.html"
    }
  ]
}
